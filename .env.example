# ============================================
# SİVAS BELEDİYESİ VEKTÖRLE MÜCADELE SİSTEMİ
# ORTAM YAPILANDIRMA DOSYASI - ÖRNEK
# ============================================
# Bu dosyayı .env olarak kopyalayıp kendi değerlerinizi girin
# cp .env.example .env  (veya copy .env.example .env)

# Sunucu Portu
PORT=3000

# Sunucu IP (0.0.0.0 = ağdaki tüm bilgisayarlardan erişilebilir)
HOST=0.0.0.0

# ============================================
# VERİTABANI TÜRÜ SEÇİMİ
# ============================================
# Veritabanı türü zorunlu kılınabilir: 'postgres', 'mssql' veya 'sqlite'
# Eğer boş bırakılırsa sırasıyla PostgreSQL, MSSQL dener, en son SQLite'a düşer.
# PostgreSQL entegrasyonu için 'postgres' olarak kilitlenmesi önerilir.
DB_TYPE=postgres

# PostgreSQL Bağlantı Bilgileri
PG_HOST=SUNUCU_IP_ADRESI
PG_PORT=5432
PG_DATABASE=VERITABANI_ADI
PG_USER=KULLANICI_ADI
PG_PASSWORD=SIFRE
PG_CONNECTION_TIMEOUT=5000

# MSSQL Bağlantı Bilgileri
MSSQL_HOST=SUNUCU_IP_ADRESI
MSSQL_PORT=1433
MSSQL_DATABASE=VERITABANI_ADI
MSSQL_USER=KULLANICI_ADI
MSSQL_PASSWORD=SIFRE
MSSQL_CONNECTION_TIMEOUT=5000
MSSQL_ENCRYPT=false

# Güvenlik
JWT_SECRET=BURAYA_GUCLU_BIR_ANAHTAR_YAZIN
JWT_EXPIRES_IN=24h

# Ortam
NODE_ENV=production
LOG_LEVEL=info
